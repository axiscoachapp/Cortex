VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_GOOGLE_CLIENT_ID="your-google-client-id"

# Dev-only: admin bypass account (create manually in Supabase Auth dashboard).
# Never set these in production. Vite strips this code from prod bundles.
VITE_BYPASS_EMAIL="dev.bypass@your-project.local"
VITE_BYPASS_PASSWORD="strong-dev-password-here"
